{
  "ConnectionStrings": {
    "DefaultConnection": "SET_VIA_ENVIRONMENT_VARIABLE"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Information"
    }
  },
  "CorsOrigins": {
    "AllowedOrigins": []
  },
  "OpenIddict": {
    "UseEphemeralKeys": true
  },
  "DynamicClientRegistration": {
    "Enabled": true,
    "RequireInitialAccessToken": true,
    "RequireAdminApproval": true,
    "AllowLocalhostRedirectUris": true,
    "AllowHttpLocalhostRedirectUris": true,
    "AllowedScopes": [
      "openid",
      "profile",
      "email",
      "offline_access",
      "roles",
      "urn:andy-docs-api"
    ]
  }
}
